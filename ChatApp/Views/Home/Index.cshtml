@{
    Layout = null;
}
<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <title>
        Chat App
    </title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js">
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/5.0.13/signalr.min.js">
    </script>
</head>

<body>
    <div id="mainDiv">
        <div id="roomsDiv">
            <div id="roomsHeadDiv">
                <span id="chatSpan">Your Chats:</span>
            </div>

            <ul class="roomsUl"></ul>
            <div id="roomsFootDiv">
                <div id="profileDiv">
                    <img id="profileImg" src="~/images/profile.png" width="25" height="25" />
                    <p id="profileP"></p>
                </div>
                <button id="newGroupBtn"><img src="~/images/chat.png" width="25" height="25" /></button>
                <button id="logOutBtn"><img src="~/images/logout.png" width="25" height="25" /></button>
            </div>
        </div>

        <div id="subMainDiv">
            <div id="headerDiv">
                <span id="headerSpan">
                </span>
            </div>

            <div id="chatDiv"></div>

            <div id="barDiv">
                
                <input type="text" id="messageBar" name="messageBar" placeholder="Enter your message">
                <button id="sendButton" type="submit" class="messageButton">➤</button>
            </div>
        </div>
    </div>

    <div id="authSection">
        <h2 id="loginH">Welcome Back!</h2>
        <input type="text" id="loginUsername" class="loginInput" placeholder="Username"><br>
        <input type="password" id="loginPassword" class="loginInput" placeholder="Password"><br>
        <button id="loginBtn" class="loginButton">Login</button>
        <button id="registerBtn" class="loginButton">Register</button>
    </div>

    <div id="userInfoPopup" style="display:none;">
        <h2 id="userH"><strong>User Info</strong></h2>

        <p id="nameP"><strong>Name: </strong> <span id="infoName"></span></p>
        <p id="lastOnlineP"><strong>Last Online: </strong> <span id="infoLastOnline"></span></p>
        <p id="groupsP"><strong>Mutual Groups: </strong><span id="infoGroups"></span></p>

        <p id="adminP"><strong>Admin: </strong><span id="infoAdmin"></span></p>

        <div id="membersContainer">
            <strong>Members:</strong>
            <div id="infoMembers"></div>
        </div>

        <button id="addUserBtn" style="display:none;">Add User</button>
        <button id="deleteGroupBtn" style="display:none;">Delete Group</button>
        <button id="leaveGroupBtn" style="display:none;">Leave Group</button>

        <button id="closeInfoPopup"><img src="~/images/close.png" width="25" height="25" /></button>
    </div>


    <div id="profilePopup">

        <button id="deleteProfileBtn">
            Delete My Account
        </button>

        <button id="closeProfilePopup"><img src="~/images/close.png" width="25" height="25" /></button>
    </div>

    <script>
        const apiBase = "/api/user";

        let connection = null;
        let currentRoom = null;
        let currentRoomType = null;

        function disconnectIfExists() {
            if (connection) {
                try { connection.stop(); } catch {}
                connection = null;
            }
        }


       
        $("#mainDiv").hide();

       
        $("#registerBtn").click(async () => {
            const username = $("#loginUsername").val();
            const password = $("#loginPassword").val();

            const response = await fetch(apiBase + "/register", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ username, password })
            });

            const text = await response.text();
            alert(text);
        });


        
        $("#loginBtn").click(async () => {
            const username = $("#loginUsername").val();
            const password = $("#loginPassword").val();

            const response = await fetch(apiBase + "/login", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ username, password })
            });

            if (response.ok) {
                const data = await response.json();
                sessionStorage.setItem("jwtToken", data.token);

                
                $("#authSection").hide();
                $("#mainDiv").show();

                disconnectIfExists();
                await startChat();
                await loadGroups();
                $("#profileP").text(username);

            } else {
                alert("Login failed.");
            }
        });

        $("#authSection").on("keydown", async function(e){
            if (e.key === "Enter") {
                const username = $("#loginUsername").val();
                const password = $("#loginPassword").val();

                const response = await fetch(apiBase + "/login", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ username, password })
                });

                if (response.ok) {
                    const data = await response.json();
                    sessionStorage.setItem("jwtToken", data.token);


                    $("#authSection").hide();
                    $("#mainDiv").show();

                    disconnectIfExists();
                    await startChat();
                    await loadGroups();
                    $("#profile").text(username);

                }else {
                    alert("Login failed.");
                }
            }
        });




                let lastRenderedDate = null;

        function getSimpleDate(dateObj) {
            // Returns "YYYY-MM-DD" for comparison
            return dateObj.toISOString().split('T')[0];
        }

        function formatDateForDivider(dateObj) {
            const today = new Date();
            const yesterday = new Date();
            yesterday.setDate(today.getDate() - 1);

            const dateStr = getSimpleDate(dateObj);

            if (dateStr === getSimpleDate(today)) {
                return "Today";
            } else if (dateStr === getSimpleDate(yesterday)) {
                return "Yesterday";
            } else {
                return dateObj.toLocaleDateString(); // e.g. "12/05/2024"
            }
        }

        function appendDateDividerIfNeeded(timestamp) {
            const dateObj = new Date(timestamp);
            const dateString = getSimpleDate(dateObj);

            // If the date has changed since the last message we rendered
            if (lastRenderedDate !== dateString) {
                const displayDate = formatDateForDivider(dateObj);
                $("#chatDiv").append(
                    `<div class="date-divider"><span>${displayDate}</span></div>`
                );
                lastRenderedDate = dateString; // Update tracker
            }
        }

        // --- MAIN FUNCTION ---
        async function startChat() {
            const token = sessionStorage.getItem("jwtToken");
            console.log("JWT Token before connecting:", token);
            if (!token) return alert("You must log in first!");

            connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub", {
                    accessTokenFactory: () => token
                })
                .build();


            // 1. RECEIVE MESSAGE (Updated with Date Divider)
            connection.on("ReceiveMessage", (user, message, timestamp) => {
                // Check for date change
                appendDateDividerIfNeeded(timestamp);

                const time = new Date(timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

                if (user == $("#loginUsername").val()) {
                    $("#chatDiv").append(`<div class="messageDiv" id="messageDivPov"> <p id="messageP"> ${message} </p> <p id="timeP"> [${time}] </p> </div>`);
                } else {
                    $("#chatDiv").append(`<div class="messageDiv" id="messageDivOther"> <p id="userP">${user}</p> <p id="messageP"> ${message} </p> <p id="timeP"> [${time}] </p> </div>`);
                }

                const chat = $("#chatDiv")[0];
                chat.scrollTop = chat.scrollHeight;
            });


            // 2. LOAD HISTORY (Updated with Date Divider)
            connection.on("LoadChatHistory", messages => {
                $("#chatDiv").empty();

                // IMPORTANT: Reset the date tracker when loading a new chat
                lastRenderedDate = null;

                messages.forEach(m => {
                    // Check for date change
                    appendDateDividerIfNeeded(m.timestamp);

                    const date = new Date(m.timestamp);
                    const time = date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

                    if (m.user == $("#loginUsername").val()) {
                        $("#chatDiv").append(`<div class="messageDiv" id="messageDivPov"> <p id="messageP"> ${m.message} </p> <p id="timeP"> [${time}] </p> </div>`);
                    } else {
                        $("#chatDiv").append(`<div class="messageDiv" id="messageDivOther"> <p id="userP">${m.user}</p> <p id="messageP"> ${m.message} </p> <p id="timeP"> [${time}] </p> </div>`);
                    }
                });

                const chat = $("#chatDiv")[0];
                chat.scrollTop = chat.scrollHeight;
            });


            // 3. GROUP ADDED (Unchanged)
            connection.on("GroupAdded", (groupName) => {
                loadGroups();
            });


            // 4. GROUP REMOVED (Unchanged, corrected ID)
            connection.on("GroupRemoved", (groupName) => {
                loadGroups();

                if (currentRoom === groupName) {
                    alert("You were removed from this group");

                    currentRoom = null;
                    currentRoomType = null;
                    $("#chatDiv").empty(); // Corrected from #chatMessages to #chatDiv to match your HTML
                    $("#messageInput").prop("disabled", true);
                    $("#sendButton").prop("disabled", true);
                }
            });


            // 5. USER DELETED (Unchanged)
            connection.on("UserDeleted", (deletedUser) => {
                console.log("User deleted:", deletedUser);

                loadGroups();

                if (currentRoom === deletedUser && currentRoomType === "private") {
                    alert("The user you are chatting with has deleted their account.");
                    $("#chatDiv").empty();
                    $("#headerSpan").empty();
                    currentRoom = null;
                    $("#messageInput").prop("disabled", true);
                    $("#sendButton").prop("disabled", true);
                }
            });


            // 6. GROUP DELETED (Unchanged)
            connection.on("GroupDeleted", (groupName) => {
                loadGroups();

                if (currentRoom === groupName && currentRoomType === "group") {
                    alert(`The group "${groupName}" was deleted.`);

                    $("#chatDiv").empty();
                    $("#headerSpan").empty();

                    currentRoom = null;
                    currentRoomType = null;

                    $("#messageInput").prop("disabled", true);
                    $("#sendButton").prop("disabled", true);
                    $("#addUserBtn").hide();
                    $("#removeUserBtn").hide();
                }
            });


            // 7. USER REGISTERED (Unchanged)
            connection.on("UserRegistered", (newUsername) => {
                console.log("New user registered:", newUsername);
                loadGroups();
            });


            // START CONNECTION
            try {
                console.log("Connecting to SignalR...");
                await connection.start();
                console.log("✅ Connected to SignalR");
            } catch (err) {
                console.error("❌ SignalR failed:", err);
                setTimeout(startChat, 3000);
            }


            // SEND BUTTON LOGIC (Unchanged)
            $("#sendButton").off("click").on("click", async function () {
                if (!currentRoom) return alert("Select a chat first!");
                const message = $("#messageBar").val().trim();
                if (!message) return;

                if (currentRoomType === "group") {
                    await connection.invoke("SendGroupMessage", currentRoom, message);
                } else if (currentRoomType === "private") {
                    await connection.invoke("SendPrivateMessage", currentRoom, message);
                }

                $("#messageBar").val("").focus();
            });

            // ENTER KEY LOGIC (Unchanged)
            $("#messageBar").on("keydown", async function (e) {
                if (e.key === "Enter") {
                    e.preventDefault();

                    if (!currentRoom) return alert("Select a chat first!");

                    const message = $(this).val().trim();
                    if (!message) return;

                    if (currentRoomType === "group") {
                        await connection.invoke("SendGroupMessage", currentRoom, message);
                    } else if (currentRoomType === "private") {
                        await connection.invoke("SendPrivateMessage", currentRoom, message);
                    }
                    $(this).val("").focus();
                }
            });
        }


        $("#newGroupBtn").click(async () => {
            const groupName = prompt("Enter group name:");
            if (!groupName) return;

            const token = sessionStorage.getItem("jwtToken");

            const response = await fetch("/api/group/create", {
                method: "POST",
                headers: {
                    "Authorization": "Bearer " + token,
                    "Content-Type": "application/json"
                },
                        body: JSON.stringify({ name: groupName })
            });

            if (response.ok) {
                alert("Group created!");
                await loadGroups();
            } else {
                alert("Failed to create group");
                console.log(await response.text());
            }
        });





        async function loadGroups() {
            const token = sessionStorage.getItem("jwtToken");
            if (!token) return;

            const response = await fetch("/api/group", {
                headers: { "Authorization": "Bearer " + token }
            });
            if (!response.ok) return;

            const allGroups = await response.json();

            const tokenPayload = JSON.parse(atob(token.split('.')[1]));
            const currentUser = tokenPayload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"];

        
            const groups = allGroups.filter(g => g.admin === currentUser || g.members.includes(currentUser));

            const roomsUl = $(".roomsUl");
            roomsUl.empty(); 

            const userResponse = await fetch("/api/userlist/all", {
                headers: { "Authorization": "Bearer " + token }
            });
            if (userResponse.ok) {
                const users = await userResponse.json();
                const imgSrcUser = '@Url.Content("~/images/profile.png")';
                users.forEach(user => {
                    roomsUl.append(`
                        <li class="roomsLi userLi" data-user="${user.username}">
                            <img id="profileImg" src="${imgSrcUser}" width="25" height="25" />
                            ${user.username}
                        </li>
                    `);
                });

            $(".userLi").off("click").on("click", async function () {
                const otherUser = $(this).data("user");
                if (currentRoom === otherUser) return;

                currentRoom = otherUser;
                currentRoomType = "private";
                $("#chatDiv").empty();
                $("#headerSpan").empty();

                $("#headerSpan").append(`<img id="profileImg" src="${imgSrcUser}" width="25" height="25" />`);
                $("#headerSpan").append(otherUser);

                $("#userInfoPopup").fadeOut(150);

                await connection.invoke("JoinPrivateChat", otherUser);
                $("#addUserBtn").hide(); 
                $("#removeUserBtn").hide();
                });
            }   


            const imgSrcGroup = '@Url.Content("~/images/group.png")';
            groups.forEach(g => {     
            roomsUl.append(
                `<li class="roomsLi groupLi" data-group="${g.name}">
                    <img id="profileImg" src="${imgSrcGroup}" width="25" height="25" />
                    ${g.name}
                </li>`);
            });

                
            $(".groupLi").off("click").on("click", async function () {
                const groupName = $(this).data("group");
                currentRoom = groupName;
                currentRoomType = "group";

                $("#chatDiv").empty();
                $("#headerSpan").empty();

                $("#userInfoPopup").fadeOut(150);

                $("#headerSpan").append(`<img id="profileImg" src="${imgSrcGroup}" width="25" height="25" />`);
                $("#headerSpan").append(groupName);

                await connection.invoke("JoinRoom", groupName);

                $("#messageInput").prop("disabled", false);
                $("#sendButton").prop("disabled", false);


                const group = groups.find(gr => gr.name === groupName);
                    if (group && group.admin === currentUser) {
                        $("#addUserBtn").show();
                        $("#removeUserBtn").show();
                        $("#deleteGroupBtn").show();
                        $("#leaveGroupBtn").hide();
                    } else {
                        $("#addUserBtn").hide();
                        $("#removeUserBtn").hide();
                        $("#deleteGroupBtn").hide();
                        $("#leaveGroupBtn").show();
                    }
            });
        }

        



        async function checkIfAdmin(groupName) {
            const token = sessionStorage.getItem("jwtToken");

            try {
                const response = await fetch(`/api/group/${groupName}`, {
                    headers: { "Authorization": "Bearer " + token }
                });

                if (!response.ok) {
                    console.warn("checkIfAdmin failed, NOT hiding button");
                    return; 
                }

                const group = await response.json();

                const tokenPayload = JSON.parse(atob(token.split('.')[1]));
                const currentUser = tokenPayload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"];

                if (group.admin === currentUser) {
                    $("#addUserBtn").show();
                    $("#removeUserBtn").show();
                    $("#deleteGroupBtn").show();
                    $("#leaveGroupBtn").hide();
                } else {
                    $("#addUserBtn").hide();
                    $("#removeUserBtn").hide();
                    $("#deleteGroupBtn").hide();
                    $("#leaveGroupBtn").show();
                }
            }
            catch (err) {
                console.error("checkIfAdmin error:", err);
            }
        }




                $("#addUserBtn").off("click").on("click", async () => {
            // 1. Basic Checks
            if (!currentRoom) return alert("Open a group first!");

            const usernameToAdd = prompt("Enter the username you want to add:");
            if (!usernameToAdd) return;

            const groupName = currentRoom;
            const token = sessionStorage.getItem("jwtToken");

            // 2. Send API Request
            const response = await fetch("/api/group/addUser", {
                method: "POST",
                headers: {
                    "Authorization": "Bearer " + token,
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    groupName: groupName,
                    username: usernameToAdd
                })
            });

            if (response.ok) {
                alert("User added!");

                // --- INSTANT UI UPDATE START ---

                // Find the existing list container
                const membersList = $("#infoMembers ul");

                // If the list said "No members", clear that first
                if (membersList.text().includes("No members")) {
                    membersList.empty();
                }

                // Create the new list item
                const li = $("<li>").css({ "margin-bottom": "5px" });
                li.append(`<span>${usernameToAdd} </span>`);

                const imgSrcClose = '@Url.Content("~/images/close.png")';
                // Since you are the Admin, add the Remove Button (❌) immediately
                const removeBtn = $(`<span style="cursor:pointer; margin-left:10px;" title="Remove User"><img src="${imgSrcClose}" width="15" height="15" /></span>`);

                // Attach the specific remove logic for this new user
                removeBtn.click(async function() {
                     if (!confirm(`Remove ${usernameToAdd} from the group?`)) return;

                     const delResponse = await fetch(
                        `/api/group/${encodeURIComponent(groupName)}/users/${encodeURIComponent(usernameToAdd)}`,
                        {
                            method: "DELETE",
                            headers: { "Authorization": "Bearer " + token }
                        }
                    );

                    if (delResponse.ok) {
                        li.remove(); // Remove immediately
                        loadGroups();
                    } else {
                        alert("Failed: " + await delResponse.text());
                    }
                });

                li.append(removeBtn);

                // Add to the list
                membersList.append(li);

                // --- INSTANT UI UPDATE END ---

                loadGroups(); // Update background data (left sidebar)
            } else {
                alert("Failed: " + await response.text());
            }
        });


            $("#removeUserBtn").click(async () => {
            if (!currentRoom || currentRoomType !== "group")
                return alert("Open a group first!");

            const usernameToRemove = prompt("Enter the username you want to remove:");
            if (!usernameToRemove) return;

            const groupName = currentRoom;
            const token = sessionStorage.getItem("jwtToken");

            const response = await fetch(
                `/api/group/${encodeURIComponent(groupName)}/users/${encodeURIComponent(usernameToRemove)}`,
                {
                    method: "DELETE",
                    headers: {
                        "Authorization": "Bearer " + token
                    }
                }
            );

            if (response.ok) {
                alert("User removed!");
                loadGroups();
            } else {
                alert("Failed: " + await response.text());
            }
        });



                              $("#headerSpan").on("click", async function () {
            const nameToCheck = $("#headerSpan").text().trim();
            if (!nameToCheck) return;

            // --- CASE 1: PRIVATE CHAT (VIEWING USER INFO) ---
            if (currentRoomType === "private") {
                const token = sessionStorage.getItem("jwtToken");
                const res = await fetch(`/api/user/info/${encodeURIComponent(nameToCheck)}`, {
                    headers: { "Authorization": "Bearer " + token }
                });

                if (!res.ok) { alert("User info not found."); return; }
                const data = await res.json();

                // Show/Hide relevant fields
                $("#nameP").show(); $("#lastOnlineP").show(); $("#groupsP").show();
                $("#adminP").hide(); $("#membersContainer").hide();

                $("#infoName").text(data.username ?? nameToCheck);
                $("#infoLastOnline").text(data.lastOnline ? new Date(data.lastOnline).toLocaleString() : "—");

                // --- NEW: BUILD MUTUAL GROUPS LIST ---
                const groupContainer = $("#infoGroups");
                groupContainer.empty(); // Clear previous content

                if (data.groups && data.groups.length > 0) {
                    const ul = $("<ul>").css({ "padding-left": "20px", "margin": "5px 0" });
                    data.groups.forEach(grp => {
                        const li = $("<li>").text(grp).css({ "margin-bottom": "5px" });
                        ul.append(li);
                    });
                    groupContainer.append(ul);
                } else {
                    groupContainer.text("—");
                }
                // -------------------------------------

                // Hide Group Buttons
                $("#addUserBtn").hide(); $("#deleteGroupBtn").hide(); $("#leaveGroupBtn").hide();

                $("#userInfoPopup").fadeIn(150);
                return;
            }

            // --- CASE 2: GROUP CHAT (VIEWING GROUP MEMBERS) ---
            if (currentRoomType === "group") {
                const token = sessionStorage.getItem("jwtToken");
                const res = await fetch(`/api/group/${encodeURIComponent(nameToCheck)}`, {
                    headers: { "Authorization": "Bearer " + token }
                });

                if (!res.ok) { alert("Group info not found."); return; }
                const g = await res.json();

                // Show/Hide relevant fields
                $("#nameP").show(); $("#lastOnlineP").hide(); $("#groupsP").hide();
                $("#adminP").show(); $("#membersContainer").show();

                $("#infoName").text(g.name);
                $("#infoAdmin").text(g.admin);

                // --- CHECK IF I AM ADMIN ---
                const tokenPayload = JSON.parse(atob(token.split('.')[1]));
                const currentUser = tokenPayload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"];
                const isAdmin = (g.admin === currentUser);

                // --- BUILD MEMBER LIST ---
                const container = $("#infoMembers");
                container.empty();

                const ul = $("<ul>").css({ "padding-left": "20px", "margin": "5px 0" });

                if (g.members && g.members.length > 0) {
                    g.members.forEach(member => {
                        const li = $("<li>").css({ "margin-bottom": "5px" });

                        // Add Name
                        li.append(`<span>${member} </span>`);

                        // IF ADMIN: Add Remove Button (❌)
                        if (isAdmin && member !== currentUser) {
                            const imgSrcClose = '@Url.Content("~/images/close.png")';
                            const removeBtn = $(`<span style="cursor:pointer; margin-left:10px;" title="Remove User"><img src="${imgSrcClose}" width="15" height="15" /></span>`);

                            // ATTACH CLICK EVENT IMMEDIATELY
                            removeBtn.click(async function() {
                                 if (!confirm(`Remove ${member} from the group?`)) return;

                                 // Call API
                                 const response = await fetch(
                                    `/api/group/${encodeURIComponent(g.name)}/users/${encodeURIComponent(member)}`,
                                    {
                                        method: "DELETE",
                                        headers: { "Authorization": "Bearer " + token }
                                    }
                                );

                                if (response.ok) {
                                    // Success: Remove the <li> from the UI immediately
                                    li.remove();
                                    // Also refresh background data
                                    loadGroups();
                                } else {
                                    alert("Failed: " + await response.text());
                                }
                            });

                            li.append(removeBtn);
                        }
                        ul.append(li);
                    });
                } else {
                    ul.append("<li>No members</li>");
                }
                container.append(ul);

                // --- BUTTON VISIBILITY ---
                if (isAdmin) {
                    $("#addUserBtn").show();
                    $("#deleteGroupBtn").show();
                    $("#leaveGroupBtn").show();
                } else {
                    $("#addUserBtn").hide();
                    $("#deleteGroupBtn").hide();
                    $("#leaveGroupBtn").show();
                }

                $("#userInfoPopup").fadeIn(150);
            }
        });



        $("#closeInfoPopup").on("click", function () {
            $("#userInfoPopup").fadeOut(150);
        });


                $("#profileDiv").on("click", async function() {
            const username = $("#profileP").text().trim();

            // Fill popup with own data
            $("#infoName").text(username);
            $("#infoGroups").text("Your Profile"); // Or fetch real groups

            // SHOW the delete button because it's me
            $("#deleteProfileBtn").show();

            $("#profilePopup").fadeIn(150);
        });

        $("#closeProfilePopup").on("click", function () {
            $("#profilePopup").fadeOut(150);
        });



                $("#deleteProfileBtn").click(async () => {
            if (!confirm("Are you sure? This will permanently delete your account and you cannot login again.")) {
                return;
            }

            const token = sessionStorage.getItem("jwtToken");

            try {
                const response = await fetch(apiBase + "/delete", {
                    method: "DELETE",
                    headers: {
                        "Authorization": "Bearer " + token
                    }
                });

                if (response.ok) {
                    alert("Account deleted. Goodbye!");

                    // Cleanup local session
                    sessionStorage.removeItem("jwtToken");
                    if (connection) await connection.stop();

                    // Reload page to show login screen
                    location.reload();
                } else {
                    alert("Failed to delete account.");
                }
            } catch (err) {
                console.error("Error deleting account:", err);
                alert("An error occurred.");
            }
        });




                $("#deleteGroupBtn").click(async () => {
            const groupName = $("#infoName").text().trim();

            if (!confirm(`Are you sure you want to delete the group "${groupName}"?`)) return;

            const token = sessionStorage.getItem("jwtToken");

            try {
                const response = await fetch(`/api/group/delete/${encodeURIComponent(groupName)}`, {
                    method: "DELETE",
                    headers: { "Authorization": "Bearer " + token }
                });

                if (response.ok) {
                    alert("Group deleted!");
                    $("#userInfoPopup").fadeOut();
                    // SignalR "GroupDeleted" will handle the UI removal
                } else {
                    alert("Failed: " + await response.text());
                }
            } catch (err) {
                console.error(err);
                alert("Error deleting group");
            }
        });



                $("#leaveGroupBtn").click(async () => {
            const groupName = $("#infoName").text().trim();

            if (!confirm(`Are you sure you want to leave "${groupName}"?`)) return;

            const token = sessionStorage.getItem("jwtToken");

            try {
                const response = await fetch("/api/group/leave", {
                    method: "POST",
                    headers: {
                        "Authorization": "Bearer " + token,
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ groupName: groupName })
                });

                if (response.ok) {
                    alert("You left the group.");
                    $("#userInfoPopup").fadeOut();
                    // The "GroupRemoved" SignalR event will handle the UI cleanup automatically
                } else {
                    alert("Failed: " + await response.text());
                }
            } catch (err) {
                console.error(err);
                alert("Error leaving group");
            }
        });




        $("#logOutBtn").click(async () => {
            location.reload();
        });





        window.addEventListener("beforeunload", () => {
            try {
                if (connection) connection.stop();
            } catch {}

            const token = sessionStorage.getItem("jwtToken");
            if (!token) return;

            const blob = new Blob([token], { type: "text/plain" });
            navigator.sendBeacon("/api/user/disconnect", blob);
        });

    </script>
</body>

</html>